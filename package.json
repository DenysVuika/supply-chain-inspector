{
  "name": "supply-chain-inspector",
  "version": "1.3.0",
  "description": "Standalone, zero-dependency CLI for npm supply chain security analysis — vulnerability scanning, OpenSSF Scorecard, install-script detection, publisher history, and more.",
  "type": "module",
  "bin": {
    "supply-chain-inspector": "inspect-dependencies.js",
    "nsci": "inspect-dependencies.js"
  },
  "files": [
    "inspect-dependencies.js",
    "README.md",
    "LICENSE",
    "assets/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "supply-chain",
    "security",
    "npm",
    "audit",
    "vulnerability",
    "scorecard",
    "openssf",
    "osv",
    "cli",
    "dependencies",
    "devops",
    "sbom"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denysvuika/supply-chain-inspector.git"
  },
  "homepage": "https://github.com/denysvuika/supply-chain-inspector#readme",
  "bugs": {
    "url": "https://github.com/denysvuika/supply-chain-inspector/issues"
  },
  "devDependencies": {
    "semantic-release": "^25.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/github": "^12.0.8"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
