{
  "name": "supply-chain-inspector",
  "version": "1.4.0",
  "description": "Standalone, zero-dependency CLI for npm supply chain security analysis — vulnerability scanning, OpenSSF Scorecard, install-script detection, publisher history, and more.",
  "type": "module",
  "bin": {
    "supply-chain-inspector": "inspect-dependencies.js",
    "nsci": "inspect-dependencies.js"
  },
  "files": [
    "cache.js",
    "inspect-dependencies.js",
    "README.md",
    "LICENSE",
    "assets/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "supply-chain",
    "security",
    "npm",
    "audit",
    "vulnerability",
    "scorecard",
    "openssf",
    "osv",
    "cli",
    "dependencies",
    "devops",
    "sbom"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DenysVuika/supply-chain-inspector"
  },
  "homepage": "https://github.com/DenysVuika/supply-chain-inspector#readme",
  "bugs": {
    "url": "https://github.com/DenysVuika/supply-chain-inspector/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
